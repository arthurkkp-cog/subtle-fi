{
  "name": "subtletech-banking",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.8.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "dev:client": "turbo run dev --filter=@subtletech/client",
    "dev:server": "turbo run dev --filter=@subtletech/server",
    "build:client": "turbo run build --filter=@subtletech/client",
    "build:server": "turbo run build --filter=@subtletech/server"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "3.2.5"
  }
}
